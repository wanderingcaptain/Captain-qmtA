# -----------------------------------------------------------------------------
# QMT_THS 系统环境变量配置模板
# 复制此文件为 .env 并填入真实配置以启用相关功能
# -----------------------------------------------------------------------------

# --- 1. East Money push2 代理网关 ---
# 必填。用于获取高频量比数据，防止本地 IP 被封禁。
# 请向代理服务商获取并填写对应信息。
QMT_PROXY_HOST="101.201.173.125"
QMT_PROXY_TOKEN="202605189JYUMHB0"

# --- 2. 覆盖 settings.toml 的宏观配置（可选） ---
# 可通过环境变量覆盖默认参数。格式: QMT_[大写模块名]_[大写参数名]
# 例如覆盖宏观情绪触发阈值：
# QMT_MACRO_CIRCUIT_BREAKER_ADVANCING_BELOW=4000
# QMT_MACRO_ADVANCING_STOCKS_THRESHOLD=3000

# --- 3. 覆盖通知渠道配置（可选） ---
# 如果不想写死在 settings.toml 中，可通过环境变量注入 Token
# QMT_NOTIFY_WECHAT_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY"
# QMT_NOTIFY_DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"
# QMT_NOTIFY_TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"
# QMT_NOTIFY_TELEGRAM_CHAT_ID="YOUR_CHAT_ID"
